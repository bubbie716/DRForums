DATABASE_URL="postgresql://user:password@localhost:5432/dr_forums?schema=public"
MINECRAFT_PLUGIN_API_KEY="your-secret-plugin-api-key"
# Set to "false" to allow posting without Minecraft verification (testing only)
MINECRAFT_VERIFICATION_REQUIRED="true"
# Vercel Blob — required on Vercel for profile avatar/banner uploads.
# Local dev falls back to /public/uploads when unset.
BLOB_READ_WRITE_TOKEN=""
