generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  passwordHash      String
  role              Role      @default(USER)
  sessionVersion    Int       @default(0)
  minecraftUuid     String?   @unique
  minecraftUsername String?
  minecraftLinkedAt DateTime?
  bio               String?
  avatarUrl         String?
  bannerUrl         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  threads                    Thread[]
  posts                      Post[]
  sessions                   Session[]
  postReactions              PostReaction[]
  messageReactions           MessageReaction[]
  conversationParticipants   ConversationParticipant[]
  sentMessages               Message[]
  mentionsReceived           Mention[]                 @relation("MentionsReceived")
  mentionsSent               Mention[]                 @relation("MentionsSent")
  forumNotificationsReceived ForumNotification[]       @relation("ForumNotificationsReceived")
  forumNotificationsSent     ForumNotification[]       @relation("ForumNotificationsSent")
  bans                       Ban[]                     @relation("BannedUser")
  bansIssued                 Ban[]                     @relation("BannedBy")
  bansLifted                 Ban[]                     @relation("LiftedBy")
  userRoles                  UserRole[]
  rolesAssigned              UserRole[]                @relation("RoleAssignedBy")
  moderationLogsAsActor      ModerationLog[]           @relation("LogActor")
  moderationLogsAsTarget     ModerationLog[]           @relation("LogTarget")
  pollsCreated               Poll[]                    @relation("PollCreatedBy")
  pollVotes                  PollVote[]
  formsCreated               Form[]                    @relation("FormCreatedBy")
  formSubmissions            FormSubmission[]          @relation("FormSubmittedBy")
  formSubmissionsReviewed    FormSubmission[]          @relation("FormSubmissionReviewedBy")

  @@map("users")
}

model Ban {
  id           String    @id @default(cuid())
  userId       String
  bannedById   String
  reason       String
  internalNote String?
  expiresAt    DateTime?
  liftedAt     DateTime?
  liftedById   String?
  liftReason   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     User  @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy User  @relation("BannedBy", fields: [bannedById], references: [id], onDelete: Cascade)
  liftedBy User? @relation("LiftedBy", fields: [liftedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bannedById])
  @@index([expiresAt])
  @@map("bans")
}

model AppRole {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String?
  priority    Int      @default(0)
  isDefault   Boolean  @default(false)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions           RolePermission[]
  users                 UserRole[]
  forumRolePermissions  ForumRolePermission[]
  formReviewerRoles     FormReviewerRole[]

  @@map("app_roles")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  label       String
  description String?
  category    String

  roles RolePermission[]

  @@index([category])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       AppRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  assignedById String?
  createdAt    DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       AppRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User?    @relation("RoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model ModerationLog {
  id           String   @id @default(cuid())
  actorId      String?
  targetUserId String?
  action       String
  details      String?
  createdAt    DateTime @default(now())

  actor      User? @relation("LogActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser User? @relation("LogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
  @@map("moderation_logs")
}

enum ForumNotificationType {
  MENTION
  THREAD_REPLY
  POST_REACTION
  ROLE_ASSIGNED
  ROLE_REMOVED
  FORM_SUBMISSION_REVIEWED
}

model ForumNotification {
  id           String                @id @default(cuid())
  userId       String
  actorUserId  String
  type         ForumNotificationType
  postId       String?
  threadId     String?
  reactionType ReactionType?
  roleName     String?
  readAt       DateTime?
  createdAt    DateTime              @default(now())

  user   User    @relation("ForumNotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actor  User    @relation("ForumNotificationsSent", fields: [actorUserId], references: [id], onDelete: Cascade)
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  thread Thread? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, type, postId, actorUserId, reactionType])
  @@index([userId, readAt])
  @@index([actorUserId])
  @@map("forum_notifications")
}

enum MentionSource {
  FORUM
  DIRECT_MESSAGE
}

model Mention {
  id              String        @id @default(cuid())
  mentionedUserId String
  mentionerUserId String
  username        String
  source          MentionSource
  postId          String?
  messageId       String?
  readAt          DateTime?
  createdAt       DateTime      @default(now())

  mentionedUser User     @relation("MentionsReceived", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  mentionerUser User     @relation("MentionsSent", fields: [mentionerUserId], references: [id], onDelete: Cascade)
  post          Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  message       Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([mentionedUserId, readAt])
  @@index([mentionerUserId])
  @@index([postId])
  @@index([messageId])
  @@map("mentions")
}

enum ReactionType {
  THUMBS_UP
  HEART
  FIRE
  THUMBS_DOWN
  SKULL
  WITHERED_ROSE
}

model MinecraftVerificationCode {
  id                String    @id @default(cuid())
  code              String    @unique
  minecraftUuid     String
  minecraftUsername String
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime  @default(now())

  @@index([minecraftUuid])
  @@index([expiresAt])
  @@map("minecraft_verification_codes")
}

model Session {
  id             String   @id @default(cuid())
  token          String   @unique
  userId         String
  sessionVersion Int      @default(0)
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  forums               Forum[]
  forumRolePermissions ForumRolePermission[]
  forms                Form[]

  @@index([slug])
  @@map("categories")
}

model Forum {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  isLocked    Boolean  @default(false)
  categoryId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category             Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  threads              Thread[]
  forumRolePermissions ForumRolePermission[]
  form                 Form?

  @@index([categoryId])
  @@index([slug])
  @@map("forums")
}

model ForumRolePermission {
  id                  String   @id @default(cuid())
  roleId              String
  categoryId          String?
  forumId             String?
  canView             Boolean  @default(true)
  canRead             Boolean  @default(true)
  canCreateThreads    Boolean  @default(true)
  canReply            Boolean  @default(true)
  canViewOtherThreads Boolean  @default(true)
  canModerate         Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  role     AppRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  forum    Forum?    @relation(fields: [forumId], references: [id], onDelete: Cascade)

  @@unique([roleId, categoryId])
  @@unique([roleId, forumId])
  @@index([roleId])
  @@index([categoryId])
  @@index([forumId])
  @@map("forum_role_permissions")
}

model Thread {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String
  isPinned   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  viewCount  Int      @default(0)
  forumId    String
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  forum  Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  posts               Post[]
  forumNotifications  ForumNotification[]
  poll                Poll?
  formSubmission      FormSubmission?

  @@index([forumId])
  @@index([authorId])
  @@index([slug])
  @@map("threads")
}

model Poll {
  id            String    @id @default(cuid())
  threadId      String    @unique
  question      String
  allowMultiple Boolean   @default(false)
  closesAt      DateTime?
  isClosed      Boolean   @default(false)
  isAnonymous   Boolean   @default(false)
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  thread    Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdBy User         @relation("PollCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  options   PollOption[]
  votes     PollVote[]

  @@index([createdById])
  @@map("polls")
}

model PollOption {
  id        String   @id @default(cuid())
  pollId    String
  label     String
  sortOrder Int
  createdAt DateTime @default(now())

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, optionId, userId])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}

model Post {
  id             String   @id @default(cuid())
  content        String
  threadId       String
  authorId       String
  replyToPostId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  thread    Thread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions           PostReaction[]
  mentions            Mention[]
  forumNotifications  ForumNotification[]

  @@index([threadId])
  @@index([authorId])
  @@map("posts")
}

model PostReaction {
  id        String       @id @default(cuid())
  type      ReactionType
  postId    String
  userId    String
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
  @@map("post_reactions")
}

model Conversation {
  id        String   @id @default(cuid())
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participants")
}

model Message {
  id                String    @id @default(cuid())
  conversationId    String
  senderId          String
  subject           String?
  content           String
  replyToMessageId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions    MessageReaction[]
  mentions     Mention[]

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model MessageReaction {
  id        String       @id @default(cuid())
  type      ReactionType
  messageId String
  userId    String
  createdAt DateTime     @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, type])
  @@index([messageId])
  @@map("message_reactions")
}

enum FormFieldType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  DROPDOWN
  CHECKBOX
  RADIO
  DATE
}

enum FormSubmissionStatus {
  PENDING
  ACCEPTED
  DENIED
  CLOSED
}

model Form {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String?
  buttonLabel   String   @default("Submit")
  isOpen        Boolean  @default(true)
  requiresLogin Boolean  @default(true)
  categoryId    String
  forumId       String   @unique
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category      Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  forum         Forum              @relation(fields: [forumId], references: [id], onDelete: Cascade)
  createdBy     User               @relation("FormCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  fields        FormField[]
  submissions   FormSubmission[]
  reviewerRoles FormReviewerRole[]

  @@index([createdById])
  @@index([categoryId])
  @@index([slug])
  @@map("forms")
}

model FormReviewerRole {
  id     String @id @default(cuid())
  formId String
  roleId String

  form Form    @relation(fields: [formId], references: [id], onDelete: Cascade)
  role AppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([formId, roleId])
  @@index([formId])
  @@index([roleId])
  @@map("form_reviewer_roles")
}

model FormField {
  id          String        @id @default(cuid())
  formId      String
  label       String
  description String?
  fieldType   FormFieldType
  required    Boolean       @default(false)
  placeholder String?
  options     Json?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  form    Form               @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers SubmissionAnswer[]

  @@index([formId])
  @@map("form_fields")
}

model FormSubmission {
  id            String               @id @default(cuid())
  formId        String
  threadId      String?              @unique
  submittedById String?
  status        FormSubmissionStatus @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?
  internalNote  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  form        Form               @relation(fields: [formId], references: [id], onDelete: Cascade)
  thread      Thread?            @relation(fields: [threadId], references: [id], onDelete: SetNull)
  submittedBy User?              @relation("FormSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedBy  User?              @relation("FormSubmissionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  answers     SubmissionAnswer[]

  @@index([formId])
  @@index([submittedById])
  @@index([status])
  @@map("form_submissions")
}

model SubmissionAnswer {
  id           String   @id @default(cuid())
  submissionId String
  fieldId      String
  value        Json
  createdAt    DateTime @default(now())

  submission FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  field      FormField      @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([submissionId, fieldId])
  @@index([submissionId])
  @@index([fieldId])
  @@map("submission_answers")
}
